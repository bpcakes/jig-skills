{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bpcakes/jig-skills/main/plugins/jig-privacy-audit/skills/audit-common/templates/finding.schema.json",
  "title": "Jig Privacy Audit Finding",
  "type": "object",
  "required": [
    "id",
    "title",
    "severity",
    "confidence",
    "audit_skill",
    "surface",
    "affected_claims",
    "evidence",
    "impact",
    "recommended_fix",
    "retest_steps",
    "limitations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9-]+-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "audit_skill": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "affected_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "description"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "excerpt": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "reproduction_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "impact": {
      "type": "string"
    },
    "root_cause_hypothesis": {
      "type": "string"
    },
    "recommended_fix": {
      "type": "string"
    },
    "retest_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bpcakes/jig-skills/main/plugins/jig-privacy-audit/skills/telemetry-crash-logs-support-leakage-audit/templates/telemetry-leakage-finding.schema.json",
  "title": "Telemetry Crash Logs Support Leakage Finding",
  "type": "object",
  "required": [
    "id",
    "title",
    "severity",
    "confidence",
    "audit_skill",
    "surface",
    "sink",
    "data_classes",
    "affected_claims",
    "evidence",
    "impact",
    "recommended_fix",
    "retest_steps",
    "limitations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TCLS-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "audit_skill": {
      "const": "telemetry-crash-logs-support-leakage-audit"
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "sink": {
      "type": "object",
      "required": [
        "name",
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "analytics",
            "crash_reporter",
            "log",
            "trace",
            "metric",
            "profile",
            "session_replay",
            "support_tool",
            "impersonation",
            "export",
            "ticket",
            "warehouse",
            "queue",
            "third_party",
            "other"
          ]
        },
        "owner_or_vendor": {
          "type": "string"
        },
        "third_party": {
          "type": "boolean"
        },
        "retention": {
          "type": "string"
        },
        "readers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "data_classes": {
      "type": "array",
      "items": {
        "enum": [
          "user_content",
          "sensitive_metadata",
          "identifier",
          "secret_or_credential",
          "key_or_recovery_material",
          "operational_diagnostic",
          "support_access_artifact",
          "unknown"
        ]
      },
      "minItems": 1
    },
    "affected_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "description"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "query_or_id": {
            "type": "string"
          },
          "event_or_field": {
            "type": "string"
          },
          "transform": {
            "type": "string"
          },
          "excerpt": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "reproduction_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "impact": {
      "type": "string"
    },
    "root_cause_hypothesis": {
      "type": "string"
    },
    "recommended_fix": {
      "type": "string"
    },
    "retest_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
